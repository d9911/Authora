# ---- Server ----
NODE_ENV=development
BACKEND_PORT=3010
FRONTEND_URL=http://localhost:5178
CORS_ORIGINS=http://localhost:5178
COOKIE_SECURE=false
# Temporary staging-only opt-in. Keep false when HTTPS is available.
ALLOW_INSECURE_PUBLIC_HTTP=false

# ---- Database ----
# Supported: mongo, sqlite. Docker overrides DB_TYPE/MONGO_URI explicitly.
DB_TYPE=mongo
MONGO_URI=mongodb://127.0.0.1:27017/authora
SQLITE_FILE=./data/authora.sqlite

# ---- JWT ----
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ---- Mail (SMTP) ----
# Leave SMTP_USER / SMTP_PASS empty in local dev to log emails to the console.
OWNER_EMAIL=replace_me@example.com
SMTP_HOST=replace_me
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me

# ---- GitHub OAuth ----
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me
GITHUB_CALLBACK_URL=http://localhost:3010/api/auth/github/callback
NEXT_PUBLIC_BACKEND_URL=http://localhost:3010

# ---- Telegram bot auth ----
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_URL=https://t.me/AuthAuraBot

#там где он будет в итоге доступен (данные когда всэ заработает !)
# FRONTEND_SITE = http://d9911.zapto.org:5178/
# BACKEND_SITE= http://d9911.zapto.org:3010/
FRONTEND_SITE=http://localhost:5178/
BACKEND_SITE=http://localhost:3010/
