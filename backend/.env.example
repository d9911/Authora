# ---- Server ----
NODE_ENV=development
BACKEND_PORT=3010
FRONTEND_URL=http://localhost:5178
CORS_ORIGINS=http://localhost:5178

# ---- Database ----
# Supported: mongo, sqlite  (postgres is stubbed for later)
DB_TYPE=sqlite
# For local `make dev` use 127.0.0.1. In Docker compose this is overridden to
# mongodb://mongo:27017/authora automatically — do NOT rely on this value there.
MONGO_URI=mongodb://127.0.0.1:27017/authora
# SQLite database file (used when DB_TYPE=sqlite). Use ":memory:" for ephemeral.
SQLITE_FILE=./data/authora.sqlite

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ---- Mail (SMTP) ----
# Leave SMTP_USER / SMTP_PASS empty in dev to log emails to the console.
OWNER_EMAIL=test@d9911.org
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ---- GitHub OAuth (post-MVP) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3010/api/auth/github/callback

# ---- Telegram (post-MVP) ----
TELEGRAM_BOT_TOKEN=
# Bot deep-link base (from BotFather), e.g. https://t.me/AuthAuraBot
TELEGRAM_BOT_URL=

# ---- Public URLs (where the app is reachable once deployed) ----
FRONTEND_SITE=http://localhost:5178/
BACKEND_SITE=http://localhost:3010/
