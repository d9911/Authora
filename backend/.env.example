# ---- Server ----
NODE_ENV=development
BACKEND_PORT=3010
FRONTEND_URL=http://localhost:5178
CORS_ORIGINS=http://localhost:5178

COOKIE_SECURE=false
# ---- Database ----
# Supported: mongo, sqlite  (postgres is stubbed for later)
DB_TYPE=mongo
# DB_TYPE=sqlite // local
MONGO_URI=mongodb://127.0.0.1:27017/authora
# SQLite database file (used when DB_TYPE=sqlite). Use ":memory:" for ephemeral.
SQLITE_FILE=./data/authora.sqlite

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ---- Mail (SMTP) ----
# Leave SMTP_USER / SMTP_PASS empty in dev to log emails to the console.
OWNER_EMAIL=test@d9911.org
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=d.9911@mail.ru
SMTP_PASS=JXK2N...

# ---- GitHub OAuth (post-MVP) ----
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=d1d75e3....
GITHUB_CALLBACK_URL=http://localhost:3010/api/auth/github/callback

# ---- Telegram (post-MVP) ----
TELEGRAM_BOT_TOKEN=8460...
TELEGRAM_BOT_URL=https://t.me/AuthAuraBot

