{
  "name": "authora-backend",
  "version": "0.1.0",
  "description": "Authora backend — Express + GraphQL + Clean Architecture (Mongo / SQLite)",
  "main": "dist/app/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "seed": "ts-node-dev --transpile-only src/infrastructure/database/mongo/seed.ts",
    "seed:mongo": "ts-node-dev --transpile-only src/infrastructure/database/mongo/seed.ts",
    "seed:sqlite": "ts-node-dev --transpile-only src/infrastructure/database/sqlite/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^17.0.2",
    "graphql-http": "^1.22.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "ruru": "^2.0.0",
    "sharp": "^0.35.3",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^7.0.2"
  }
}
