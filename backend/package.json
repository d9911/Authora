{
  "name": "authora-backend",
  "version": "0.1.0",
  "description": "Authora backend — Express + GraphQL + Clean Architecture (Mongo / SQLite)",
  "main": "dist/app/server.js",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "yarn": "1.22.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "seed": "ts-node-dev --transpile-only src/infrastructure/database/mongo/seed.ts",
    "seed:mongo": "ts-node-dev --transpile-only src/infrastructure/database/mongo/seed.ts",
    "seed:sqlite": "ts-node-dev --transpile-only src/infrastructure/database/sqlite/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "node ../tests/backend-clean-architecture-boundaries.mjs && tsc --noEmit",
    "test:account-recovery": "yarn run build && node tests/environment-validation.test.cjs && node tests/mail-service-templates.test.cjs && node tests/account-recovery-use-cases.test.cjs && node tests/telegram-recovery-ticket.test.cjs",
    "test:smoke:compile": "tsc -p tsconfig.smoke.json",
    "test:smoke:sqlite": "yarn run test:smoke:compile && node tests/telegram-ticket-repository.test.cjs && node .smoke-dist/smoke-test-sqlite.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.33",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-http": "^1.22.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4",
    "ruru": "^2.0.0",
    "sharp": "^0.35.3",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "autocannon": "7",
    "mongodb-memory-server": "^11.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^7.0.2"
  }
}
