{
  "name": "authora-backend",
  "version": "0.1.0",
  "description": "Fullstack app backend — Express + GraphQL + Clean Architecture (MVP: MongoDB)",
  "main": "dist/app/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "seed": "ts-node-dev --transpile-only src/infrastructure/database/mongo/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "nodemailer": "^6.9.14",
    "qrcode": "^1.5.4",
    "ruru": "^2.0.0-beta.11",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
