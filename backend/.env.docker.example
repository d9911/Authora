# ---- Authora backend — DOCKER secrets ----
# Copy to backend/.env.docker and fill in real values. This file is loaded by
# docker-compose for the backend container. DO NOT put DB_TYPE / MONGO_URI /
# SQLITE_FILE here — those are set deterministically in docker-compose.yml.

# Mail (SMTP). Leave empty to log emails to the console.
OWNER_EMAIL=
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3010/api/auth/github/callback

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_URL=

# JWT (override the insecure compose defaults in production)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
