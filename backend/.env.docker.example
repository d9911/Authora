# ---- Authora backend — Docker-only secret overrides ----
# docker-compose loads backend env in this order: .env, backend/.env,
# backend/.env.docker. Copy this file to backend/.env.docker only when Docker
# needs values that differ from local backend/.env.
# DO NOT put DB_TYPE / MONGO_URI / SQLITE_FILE here: those are set
# deterministically in docker-compose.yml and docker-compose.mongo.yml.

# Temporary staging-only opt-in. Keep false when HTTPS is available.
ALLOW_INSECURE_PUBLIC_HTTP=false

# Mail (SMTP). Leave SMTP_USER / SMTP_PASS empty to log emails to the console.
OWNER_EMAIL=replace_me@example.com
SMTP_HOST=replace_me
SMTP_PORT=587
SMTP_USER=replace_me
SMTP_PASS=replace_me

# GitHub OAuth
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me
GITHUB_CALLBACK_URL=http://localhost:3010/api/auth/github/callback

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_URL=https://t.me/replace_me_bot

# JWT (override the insecure compose defaults in production)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
