# Frontend runtime
FRONTEND_PORT=5178

# Backend URL used ONLY by the server-side proxy (not exposed to the browser)
BACKEND_INTERNAL_URL=http://localhost:3010

# Set to "true" ONLY behind HTTPS. Over http://localhost keep it false so the
# session cookies set by the proxy are not dropped by the browser.
COOKIE_SECURE=false

# Public backend URL for full-page OAuth redirects (GitHub / Telegram).
# In Docker / prod set this to the externally reachable backend address,
# e.g. http://d9911.zapto.org:3010
NEXT_PUBLIC_BACKEND_URL=http://localhost:3010

# Telegram bot username (without @) to render the Telegram Login Widget.
# Leave empty to hide the Telegram button.
NEXT_PUBLIC_TELEGRAM_BOT=AuthAuraBot

# Public app config (safe to expose)
NEXT_PUBLIC_APP_NAME=Authora
